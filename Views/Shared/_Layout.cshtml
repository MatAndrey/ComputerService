@using Microsoft.AspNetCore.Builder
@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Options

@inject IViewLocalizer Localizer
@inject IOptions<RequestLocalizationOptions> LocOptions

@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var cultureItems = LocOptions.Value.SupportedUICultures
        .Select(c => new SelectListItem { Value = c.Name, Text = c.NativeName })
        .ToList();
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ComputerService</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <script src="https://ajax.aspnetcdn.com/ajax/jquery/jquery-3.7.1.min.js" asp-fallback-src="~/lib/jquery/dist/jquery.min.js"></script>
</head>
<body>
    <header>
        <div class="search_bar">
            <h1><a asp-action="Index" asp-controller="Home">BSOD</a></h1>
            <input type="search" placeholder="@Localizer["Find product"]" name="search" autocomplete="off" />
            <button id="submit_search">
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#fff"><path d="M784-120 532-372q-30 24-69 38t-83 14q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l252 252-56 56ZM380-400q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z" /></svg>
            </button>
            <a asp-action="Index" asp-controller="Cart" class="search_bar_btn">
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#fff"><path d="M223.5-103.5Q200-127 200-160t23.5-56.5Q247-240 280-240t56.5 23.5Q360-193 360-160t-23.5 56.5Q313-80 280-80t-56.5-23.5Zm400 0Q600-127 600-160t23.5-56.5Q647-240 680-240t56.5 23.5Q760-193 760-160t-23.5 56.5Q713-80 680-80t-56.5-23.5ZM246-720l96 200h280l110-200H246Zm-38-80h590q23 0 35 20.5t1 41.5L692-482q-11 20-29.5 31T622-440H324l-44 80h480v80H280q-45 0-68-39.5t-2-78.5l54-98-144-304H40v-80h130l38 80Zm134 280h280-280Z" /></svg>
            </a>
            <a asp-action="Index" asp-controller="Orders" class="search_bar_btn">
                <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#fff"><path d="M160-160v-516L82-846l72-34 94 202h464l94-202 72 34-78 170v516H160Zm240-280h160q17 0 28.5-11.5T600-480q0-17-11.5-28.5T560-520H400q-17 0-28.5 11.5T360-480q0 17 11.5 28.5T400-440ZM240-240h480v-358H240v358Zm0 0v-358 358Z" /></svg>
            </a>
        </div>
        <nav>
            <ul>
                <li><a asp-action="About" asp-controller="Home">@Localizer["About"]</a></li>
                <li><a asp-action="News" asp-controller="Home">@Localizer["News"]</a></li>
                <li><a asp-action="Index" asp-controller="Feedback">@Localizer["Feedback"]</a></li>
                <li><a asp-action="Sitemap" asp-controller="Home">@Localizer["Sitemap"]</a></li>
                <li>
                    <form method="post" asp-action="SetLanguage" asp-controller="Language" asp-route-returnUrl="@Context.Request.Path" class="lang_form">
                        <select name="culture" onchange="this.form.submit();"
                                asp-for="@requestCulture.RequestCulture.UICulture.Name"
                                asp-items="cultureItems">
                        </select>
                    </form>
                </li>
            </ul>
        </nav>
    </header>
    <hr />
    <main>
        @RenderBody()
    </main>
    <hr />
    <footer>
        <p>
            @Localizer["Copyright"]
        </p>
        <nav>
            <ul>
                <li><a asp-action="Index" asp-controller="Support">@Localizer["Support"]</a></li>
                <li><a asp-action="Contacts" asp-controller="Home">@Localizer["Contacts"]</a></li>
                <li><a asp-action="Directions" asp-controller="Home">@Localizer["Directions"]</a></li>
                <li><a asp-action="History" asp-controller="Home">@Localizer["History"]</a></li>
                <li><a asp-action="Login" asp-controller="Auth">@Localizer["I'm admin"]</a></li>
            </ul>
        </nav>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
