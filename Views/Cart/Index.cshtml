@using ComputerService.ViewModels
@model IEnumerable<CartItemViewModel>
@inject IViewLocalizer Localizer
@{
	ViewData["Title"] = @Localizer["Cart"];
}

<h2>@Localizer["Cart"]</h2>

<div class="cart_items">
	@if(Model.Any())
	@foreach(var item in Model)
	{
		<div class="cart_item">
			<div class="cart_item_img">
				<img src="@item.ImageUrl" alt="Item image" />
			</div>
			<div>
				<h3><a asp-action="Product" asp-controller="Products" asp-route-id="@item.ProductId">@item.Name</a></h3>
				<p>@item.Price.ToString("N0") ₽ @(item.Quantity == 0 ? "" : $"× {item.Quantity} = {(item.Quantity * item.Price).ToString("N0")} ₽")</p>
			</div>
			</div>
		}

	else
	{
		<p>@Localizer["Cart is empty now"] <a asp-action="Index" asp-controller="Products">@Localizer["Go to products"]</a></p>
	}
</div>