@using System.Globalization
@model IEnumerable<CategoryViewModel>
@inject IViewLocalizer Localizer
@{
	ViewData["Title"] = Localizer["Categories"];
	var culture = CultureInfo.CurrentUICulture.Name;
}

<div class="categories_list">
	<h2>@Localizer["Categories"]</h2>
	<div class="category_item">
		<input type="text" placeholder="@Localizer["Category name"]" id="create_category_field" />
		<div class="category_actions">
			<button 
				id="create_category_btn" 
				class="category_action_btn" 
				disabled 
				title="@Localizer["Create"]">
				<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M440-280h80v-160h160v-80H520v-160h-80v160H280v80h160v160Zm40 200q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z" /></svg>
			</button>
		</div>
	</div>
	@if(!Model.Any())
	{
		<p class="no_categories">@Localizer["No categories"]</p>
	} else foreach (var category in Model)
	{
		<div class="category_item">
			<input type="text" data-id="@category.Id" value="@category.Name" name="category_name" />
			<div class="category_actions">
				@if(culture != category.LangCode) {
					<span title="@Localizer["There is no translation on current language"]">
						<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M480-120q-33 0-56.5-23.5T400-200q0-33 23.5-56.5T480-280q33 0 56.5 23.5T560-200q0 33-23.5 56.5T480-120Zm-80-240v-480h160v480H400Z" /></svg>
					</span>
				}
				<button 
					data-id="@category.Id" 
					class="category_action_btn open_btn" 
					title="@Localizer["View Products"]">
					<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M200-120q-33 0-56.5-23.5T120-200v-560q0-33 23.5-56.5T200-840h280v80H200v560h560v-280h80v280q0 33-23.5 56.5T760-120H200Zm188-212-56-56 372-372H560v-80h280v280h-80v-144L388-332Z" /></svg>
				</button>
				<button 
					data-id="@category.Id" 
					class="category_action_btn delete_btn" 
					title="@Localizer["Delete"]" 
					disabled="@(!category.CanDelete)">
					<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M280-120q-33 0-56.5-23.5T200-200v-520h-40v-80h200v-40h240v40h200v80h-40v520q0 33-23.5 56.5T680-120H280Zm400-600H280v520h400v-520ZM360-280h80v-360h-80v360Zm160 0h80v-360h-80v360ZM280-720v520-520Z" /></svg>
				</button>
				<button 
					data-id="@category.Id" 
					class="category_action_btn save_btn" 
					title="@Localizer["Save"]" 
					disabled>
					<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M382-240 154-468l57-57 171 171 367-367 57 57-424 424Z" /></svg>
				</button>
			</div>
		</div>
	}
</div>

<script>
	$("#create_category_field").on("input", e => {
		const value = e.target.value.trim();
		if(value.length > 0) {
			$("#create_category_btn").removeAttr("disabled");
		} else {
			$("#create_category_btn").attr("disabled", "disabled");
		}
	})

	$("#create_category_btn").click(e => {
		const name = $("#create_category_field").val().trim();
		if(name.length === 0) return;
		$.post("/categories", { name }, () => {
			location.reload();
		})
	})

	$(".delete_btn").click(e => {
		const id = e.currentTarget.dataset.id;
		if(!id) return;
		$.ajax({
			url: `/categories/${id}`,
			type: "DELETE",
			success: () => {
				location.reload();
			}
		})
	})

	$(".category_item input[name='category_name']").on("input", e => {
		const value = e.target.value.trim();
		const id = e.target.dataset.id;
		const saveBtn = $(`.save_btn[data-id='${id}']`);
		if(value.length > 0) {
			saveBtn.removeAttr("disabled");
		} else {
			saveBtn.attr("disabled", "disabled");
		}
	})

	$(".save_btn").click(e => {
		const id = e.currentTarget.dataset.id;
		const input = $(`.category_item input[name='category_name'][data-id='${id}']`);
		const name = input.val().trim();
		if(name.length === 0) return;
		$.ajax({
			url: `/categories/${id}`,
			type: "PUT",
			data: { name },
			success: () => {
				location.reload();
			}
		})
	})

	$(".open_btn").click(e => {
		const id = e.currentTarget.dataset.id;
		if(!id) return;
		location.href = `/products/?categoryid=${id}`;
	})
</script>