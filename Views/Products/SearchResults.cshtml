@using System.Globalization
@using ComputerService.ViewModels
@model IEnumerable<ProductViewModel>
@inject IViewLocalizer Localizer
@{
	ViewData["Title"] = ViewData["SearchTerm"];
}

<h2>@ViewData["SearchTerm"] - @Localizer["Search results"]</h2>


@if (Model.Any())
{
<div class="products_list">
	@foreach (var product in Model)
	{
		<a class="product_item" asp-action="Product" asp-controller="Products" asp-route-id="@product.Id">

			<div class="product_image">
				<img src="@(product.ImageUrls.FirstOrDefault("https://placehold.co/600x600/FFF/000?text=No+image"))" alt="@product.Name" />
			</div>
			<div class="product_info">
				<span class="price">@(product.Price.ToString("N0")) ₽</span>
				<h3>@product.Name</h3>
			</div>
		</a>
	}
</div>
} else
{
	<p>@Localizer["Nothing found"]</p>
	<a asp-action="Index" asp-controller="Products">@Localizer["Return to home page"]</a>
}