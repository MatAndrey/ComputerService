@using ComputerService.ViewModels
@model OrderViewModel
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Order details"] + " №" + Model.Id;
}

<div class="order_details_container">
    <h2>@Localizer["Order details"] №@Model.Id</h2>

    <div>
        <table class="details_table">
            <tbody>
                <tr>
                    <th>@Localizer["Order ID"]</th>
                    <td>@Model.Id</td>
                </tr>
                <tr>
                    <th>@Localizer["Date"]</th>
                    <td>@Model.Date.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
                <tr>
                    <th>@Localizer["Customer name"]</th>
                    <td>@Model.CustomerName</td>
                </tr>
                <tr>
                    <th>@Localizer["Phone"]</th>
                    <td>@Model.Phone</td>
                </tr>
                <tr>
                    <th>@Localizer["Email"]</th>
                    <td>@Model.Email</td>
                </tr>
                <tr>
                    <th>@Localizer["Payment method"]</th>
                    <td>@Model.PaymentMethod</td>
                </tr>
                <tr>
                    <th>@Localizer["Delivery method"]</th>
                    <td>@Model.DeliveryMethod</td>
                </tr>
                <tr>
                    <th>@Localizer["Delivery address"]</th>
                    <td>@Model.DeliveryAddress</td>
                </tr>
                <tr>
                    <th>@Localizer["Total amount"]</th>
                    <td><strong>@Model.Total.ToString("N0") ₽</strong></td>
                </tr>
            </tbody>
        </table>
    </div>

    <h3>@Localizer["Order items"]</h3>
    @if (Model.Items != null && Model.Items.Any())
    {
        <div class="items_table_wrapper">
            <table class="items_table">
                <thead>
                    <tr>
                        <th>@Localizer["Product"]</th>
                        <th>@Localizer["Quantity"]</th>
                        <th>@Localizer["Price"]</th>
                        <th>@Localizer["Total"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Quantity @Localizer["pcs."]</td>
                            <td>@item.Price.ToString("N0") ₽</td>
                            <td>@((item.Price * item.Quantity).ToString("N0")) ₽</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="total_row">
                        <th colspan="3">@Localizer["Total"]</th>
                        <td><strong>@Model.Total.ToString("N0") ₽</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
    else
    {
        <p>@Localizer["No items in this order"]</p>
    }
</div>