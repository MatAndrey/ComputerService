@using ComputerService.ViewModels
@model IEnumerable<OrderViewModel>
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Orders management"];
}

<h2>@Localizer["Orders management"]</h2>

@if (Model.Any())
{
    <div>
        <table class="admin_orders_table">
            <thead>
                <tr>
                    <th>@Localizer["ID"]</th>
                    <th>@Localizer["Date"]</th>
                    <th>@Localizer["Customer"]</th>
                    <th>@Localizer["Phone"]</th>
                    <th>@Localizer["Email"]</th>
                    <th>@Localizer["Payment"]</th>
                    <th>@Localizer["Delivery method"]</th>
                    <th>@Localizer["Address"]</th>
                    <th>@Localizer["Total"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td><a asp-action="Details" asp-controller="Orders" asp-area="Admin" asp-route-id="@order.Id">@order.Id</a></td>
                        <td>@order.Date.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@order.CustomerName</td>
                        <td>@order.Phone</td>
                        <td>@order.Email</td>
                        <td>@order.PaymentMethod</td>
                        <td>@order.DeliveryMethod</td>
                        <td>@order.DeliveryAddress</td>
                        <td>@order.Total.ToString("N0") ₽</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p>@Localizer["No orders yet"]</p>
}