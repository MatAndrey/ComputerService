@using System.Globalization
@model IEnumerable<ProductViewModel>
@inject IViewLocalizer Localizer
@{
	ViewData["Title"] = @Localizer["All products"];
	var culture = CultureInfo.CurrentUICulture.Name;
}

<h2>@Localizer["All products"]</h2>

<div class="products_list">
	<a class="product_item" asp-action="CreateProduct" asp-controller="Products" asp-area="Admin">
		<div class="product_image">
			<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M440-280h80v-160h160v-80H520v-160h-80v160H280v80h160v160Zm40 200q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z" /></svg>
		</div>
		<div class="product_info">
			<h3 class="add_product">@Localizer["Add product"]</h3>
		</div>
	</a>
	@if (Model.Any())
	{
		@foreach (var product in Model)
		{
			<a class="product_item" asp-action="Product" asp-controller="Products" asp-area="Admin" asp-route-id="@product.Id">

				<div class="product_image">
					<img src="@(product.ImageUrls.FirstOrDefault())" alt="@product.Name" />
				</div>
				<div class="product_info">
					<span class="price">@(product.Price.ToString("N0")) ₽</span>
					<h3>
						@if (product.LangCode != culture)
						{
							<span title="@Localizer["There is no translation on current language"]" class="no_translation">(@product.LangCode.ToUpper())</span>
						}
						@product.Name
					</h3>
				</div>
			</a>
		}
	}
</div>