@using System.Globalization
@model ProductViewModel
@inject IViewLocalizer Localizer
@{
	ViewData["Title"] = Localizer["Edit product"];
	var culture = CultureInfo.CurrentUICulture.Name;
}


<h2>
    @Localizer["Edit product"] 
    @if(culture != Model.LangCode)
    {
        <span title="@Localizer["There is no translation on current language"]" class="no_translation">
            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="M480-120q-33 0-56.5-23.5T400-200q0-33 23.5-56.5T480-280q33 0 56.5 23.5T560-200q0 33-23.5 56.5T480-120Zm-80-240v-480h160v480H400Z" /></svg>
        </span>
    }
</h2>
<form class="product_edit" method="post" id="product_form">
	<div class="form_column">
		<div class="form_group">
            <label asp-for="Name">@Localizer["Product name"]</label>
			<input type="text" name="Name" required asp-for="Name"/>
		</div>
		<div class="form_group">
            <label asp-for="CategoryId">@Localizer["Product category"]</label>
			<select name="CategoryId" required asp-for="CategoryId">
				@foreach (var category in ViewData["categories"] as IEnumerable<CategoryViewModel>)
				{
					<option value="@category.Id" selected="@(category.Name == ViewData["selectedCategory"])">@category.Name</option>
				}
			</select>
		</div>
		<div class="form_group">
			<label for="product_description">@Localizer["Product description"]</label>
			<textarea id="product_description" name="Description" asp-for="Description"></textarea>
		</div>
		<div class="form_group">
            <label asp-for="Price">@Localizer["Product price"]</label>
			<input type="number" name="Price" step="1" required asp-for="Price"/>
		</div>
        <div class="form_group">
            <label asp-for="Visible">@Localizer["Visibility"]</label>
            <input type="checkbox" asp-for="Visible"/>
        </div>
        <div class="images_upload_list" id="imagesUploadList">
            <div class="drop_zone preview_item" id="dropZone">
                <input type="file" id="imageInput" multiple accept="image/jpeg,image/png,image/webp" style="display:none"/>
                <p>@Localizer["Select images"]</p>
            </div>
        </div>
		<div class="btn_group">
			<button class="btn" type="button" id="returnBtn">@Localizer["Return"]</button>
			<button class="btn">@Localizer["Save"]</button>
		</div>
	</div>
</form>

<script>
    let selectedFiles = [];
    let currentImageUrls = @Html.Raw(Json.Serialize(Model.ImageUrls ?? new List<string>()));

    const $dropZone = $('#dropZone');
    const $fileInput = $('#imageInput');
    const $imagesUploadList = $('#imagesUploadList');

    function openFileDialog() {
        $fileInput.trigger('click');
    }

    function addFiles(files) {
        const newFiles = Array.from(files).filter(file => {
            if (!file.type.startsWith('image/')) return false;
            return !selectedFiles.some(f => f.name === file.name && f.size === file.size);
        });

        if (newFiles.length === 0) return;

        selectedFiles = selectedFiles.concat(newFiles);

        newFiles.forEach(file => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const $item = $(`
                    <div class="preview_item" data-filename="${file.name}" data-filesize="${file.size}">
                        <img src="${e.target.result}" alt="preview">
                        <button type="button" class="remove_btn" data-filename="${file.name}" data-filesize="${file.size}">
                            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"/></svg>
                        </button>
                    </div>
                `);
                $imagesUploadList.append($item);
            };
            reader.readAsDataURL(file);
        });
    }

    $fileInput.on('change', function(e) {
        if (e.target.files && e.target.files.length) {
            addFiles(e.target.files);
        }
    });

    $dropZone.on('dragover', function(e) {
        e.preventDefault();
        $(this).addClass('drag_over');
    });

    $dropZone.on('dragleave', function(e) {
        $(this).removeClass('drag_over');
    });

    $dropZone.on('drop', function(e) {
        e.preventDefault();
        $(this).removeClass('drag_over');
        const files = e.originalEvent.dataTransfer.files;
        if (files.length) addFiles(files);
    });

    $dropZone.on('click', function(e) {
        e.stopPropagation();
        if ($(e.target).is("#imageInput")) return;
        openFileDialog();
    });

    $imagesUploadList.on('click', '.remove_btn', function() {
        const name = $(this).data('filename');
        const size = $(this).data('filesize');
		const url = $(this).data('url');
        if(name && size) {
            selectedFiles = selectedFiles.filter(f => !(f.name === name && f.size === size));
            $(`.preview_item[data-filename="${name}"][data-filesize="${size}"]`).remove();
        }
        if(url) {
            currentImageUrls = currentImageUrls.filter(u => u !== url);
            $(`.preview_item[data-url="${url}"]`).remove();
		}
    });

    $("#returnBtn").on('click', function() {
        window.history.back();
	});

    $('#product_form').on('submit', function(e) {
        e.preventDefault();
        var formData = new FormData(this);
        for (let i = 0; i < selectedFiles.length; i++) {
            formData.append('images', selectedFiles[i]);
        }

        formData.set('imageUrlsJson', JSON.stringify(currentImageUrls));

        $.ajax({
            url: `/admin/products/@Model.Id`,
            method: 'PUT',
            data: formData,
            contentType: false,
            processData: false,
            success: function(response) {
				window.location.reload()
            },
            error: function(xhr) {
                alert('Ошибка: ' + xhr.responseText);
            }
        });
    });

    function renderExistingImages() {
        currentImageUrls.forEach((url, idx) => {
            const $item = $(`
                <div class="preview_item" data-url="${url}">
                    <img src="${url}" alt="preview">
                    <button type="button" class="remove_btn" data-url="${url}">
                        <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#e3e3e3"><path d="m256-200-56-56 224-224-224-224 56-56 224 224 224-224 56 56-224 224 224 224-56 56-224-224-224 224Z"/></svg>
                    </button>
                </div>
            `);
            $imagesUploadList.append($item);
        });
    }

    renderExistingImages();
</script>